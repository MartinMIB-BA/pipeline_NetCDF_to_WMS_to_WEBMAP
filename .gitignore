### SYSTEM FILES ###
# Ignore OS-specific metadata files
.DS_Store
.AppleDouble
.LSOverride

### PYTHON ###
# Ignore Python bytecode and translation artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Ignore distribution and build folders
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

### PROJECT SPECIFIC (Pipeline & GeoServer) ###
# Ignore specific script logs and temporary files
proxy_async.py
proxy_debug.log

# Ignore large data files (NetCDF and Excel)
*.nc
*.xlsx
*.tif
*.tiff

# Ignore server directories containing large datasets or logs
data/
logs/
example_nc/
uploads/

### VIRTUAL ENVIRONMENTS & SECRETS ###
# Never commit libraries or sensitive credentials
venv/
.venv/
env/
.env

### JUPYTER NOTEBOOK ###
.ipynb_checkpoints/

### WEB / FRONTEND ###
# Ignore node modules if you add JS libraries like Leaflet
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

### BACKUPS & OLD VERSIONS ###
# Keep the repository clean of manual backups
**/old/
web/old_versions/

### INSTALLERS ###
# Ignore large binary installers
*.sh

### WEB ###
web/proxy_async.py
web/ASYNC_PROXY_GUIDE.md
web/proxy_debug.log
