### SYSTEM FILES ###
# Ignore OS-specific metadata files
.DS_Store
.AppleDouble
.LSOverride

### IDE & EDITORS ###
.idea/
.vscode/

# Ignore distribution and build folders
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Exception for scripts library
!scripts/lib/
!scripts/lib/**

### PROJECT SPECIFIC (Pipeline & GeoServer) ###
# Ignore specific script logs and temporary files
proxy_async.py
proxy_debug.log
*.log

# Ignore large data files (NetCDF and Excel)
*.nc
*.xlsx
*.tif
*.tiff
*.zip

# Ignore server directories containing large datasets or logs
data/
logs/
example_nc/
uploads/

### VIRTUAL ENVIRONMENTS & SECRETS ###
# Never commit libraries or sensitive credentials
venv/
.venv/
env/
ENV/
.env

### JUPYTER NOTEBOOK ###
.ipynb_checkpoints/
*.ipynb

### WEB / FRONTEND ###
# Ignore node modules if you add JS libraries like Leaflet
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

### BACKUPS & TEMPORARY FILES ###
# Keep the repository clean of manual backups and temp files
**/old/
web/old_versions/
*.tmp
*.bak
*.swp
*~

### WEB DIR SPECIFICS ###
web/proxy_async.py
web/ASYNC_PROXY_GUIDE.md
web/proxy_debug.log

### MONITORING ###
monitoring/nginx_logs/

### PYTHON ###
# Ignore Python bytecode and translation artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
